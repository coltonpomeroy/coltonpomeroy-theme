{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "740px",
			"wideSize": "1200px"
		},
		"color": {
			"palette": [
				{ "slug": "cream", "color": "#FBF7F0", "name": "Cream" },
				{ "slug": "charcoal", "color": "#2C2C2C", "name": "Charcoal" },
				{ "slug": "copper", "color": "#C4763B", "name": "Copper" },
				{ "slug": "copper-dark", "color": "#A05E2C", "name": "Copper Dark" },
				{ "slug": "navy", "color": "#1B2A4A", "name": "Navy" },
				{ "slug": "sage", "color": "#7A9E7E", "name": "Sage" },
				{ "slug": "terra", "color": "#D4956A", "name": "Terra" },
				{ "slug": "white", "color": "#FFFFFF", "name": "White" },
				{ "slug": "gray-50", "color": "#FAFAF8", "name": "Gray 50" },
				{ "slug": "gray-100", "color": "#F0EDE6", "name": "Gray 100" },
				{ "slug": "gray-200", "color": "#E2DDD3", "name": "Gray 200" },
				{ "slug": "gray-400", "color": "#9C9789", "name": "Gray 400" },
				{ "slug": "gray-500", "color": "#6B6760", "name": "Gray 500" },
				{ "slug": "gray-900", "color": "#1A1A1A", "name": "Gray 900" }
			],
			"gradients": [
				{
					"slug": "warm-fade",
					"gradient": "linear-gradient(135deg, #FBF7F0 0%, #F0EDE6 100%)",
					"name": "Warm Fade"
				},
				{
					"slug": "copper-glow",
					"gradient": "linear-gradient(135deg, #C4763B 0%, #D4956A 100%)",
					"name": "Copper Glow"
				},
				{
					"slug": "navy-depth",
					"gradient": "linear-gradient(180deg, #1B2A4A 0%, #2C2C2C 100%)",
					"name": "Navy Depth"
				}
			],
			"defaultPalette": false,
			"defaultGradients": false,
			"defaultDuotone": false
		},
		"typography": {
			"fluid": true,
			"fontFamilies": [
				{
					"fontFamily": "'Playfair Display', Georgia, serif",
					"slug": "display",
					"name": "Playfair Display"
				},
				{
					"fontFamily": "'Inter', -apple-system, BlinkMacSystemFont, sans-serif",
					"slug": "heading",
					"name": "Inter"
				},
				{
					"fontFamily": "'Source Serif 4', 'Source Serif Pro', Georgia, serif",
					"slug": "body",
					"name": "Source Serif 4"
				},
				{
					"fontFamily": "'JetBrains Mono', 'Fira Code', monospace",
					"slug": "mono",
					"name": "JetBrains Mono"
				}
			],
			"fontSizes": [
				{ "slug": "small", "size": "0.875rem", "name": "Small", "fluid": false },
				{ "slug": "medium", "size": "1rem", "name": "Medium", "fluid": { "min": "1rem", "max": "1.125rem" } },
				{ "slug": "large", "size": "1.25rem", "name": "Large", "fluid": { "min": "1.125rem", "max": "1.25rem" } },
				{ "slug": "x-large", "size": "1.5rem", "name": "Extra Large", "fluid": { "min": "1.25rem", "max": "1.5rem" } },
				{ "slug": "xx-large", "size": "2rem", "name": "2XL", "fluid": { "min": "1.5rem", "max": "2rem" } },
				{ "slug": "huge", "size": "3rem", "name": "Huge", "fluid": { "min": "2rem", "max": "3rem" } },
				{ "slug": "gigantic", "size": "4rem", "name": "Gigantic", "fluid": { "min": "2.5rem", "max": "4rem" } }
			]
		},
		"spacing": {
			"units": ["px", "em", "rem", "%", "vw"],
			"spacingSizes": [
				{ "slug": "10", "size": "0.25rem", "name": "1" },
				{ "slug": "20", "size": "0.5rem", "name": "2" },
				{ "slug": "30", "size": "1rem", "name": "3" },
				{ "slug": "40", "size": "1.5rem", "name": "4" },
				{ "slug": "50", "size": "2rem", "name": "5" },
				{ "slug": "60", "size": "3rem", "name": "6" },
				{ "slug": "70", "size": "4rem", "name": "7" },
				{ "slug": "80", "size": "6rem", "name": "8" },
				{ "slug": "90", "size": "8rem", "name": "9" }
			]
		},
		"blocks": {
			"core/button": {
				"border": { "radius": true }
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--cream)",
			"text": "var(--wp--preset--color--charcoal)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.7"
		},
		"spacing": {
			"padding": {
				"top": "0",
				"right": "var(--wp--preset--spacing--30)",
				"bottom": "0",
				"left": "var(--wp--preset--spacing--30)"
			}
		},
		"elements": {
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontSize": "var(--wp--preset--font-size--gigantic)",
					"fontWeight": "800",
					"lineHeight": "1.1",
					"letterSpacing": "-0.02em"
				},
				"color": { "text": "var(--wp--preset--color--charcoal)" }
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontSize": "var(--wp--preset--font-size--huge)",
					"fontWeight": "700",
					"lineHeight": "1.2"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontSize": "var(--wp--preset--font-size--xx-large)",
					"fontWeight": "600",
					"lineHeight": "1.3"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"fontWeight": "600",
					"lineHeight": "1.4"
				}
			},
			"link": {
				"color": { "text": "var(--wp--preset--color--copper)" },
				"typography": { "textDecoration": "underline" },
				":hover": {
					"color": { "text": "var(--wp--preset--color--copper-dark)" },
					"typography": { "textDecoration": "none" }
				}
			},
			"button": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "600",
					"fontSize": "var(--wp--preset--font-size--medium)",
					"letterSpacing": "0.01em"
				},
				"color": {
					"background": "var(--wp--preset--color--copper)",
					"text": "var(--wp--preset--color--white)"
				},
				"border": { "radius": "8px" },
				"spacing": {
					"padding": {
						"top": "0.8rem",
						"right": "2rem",
						"bottom": "0.8rem",
						"left": "2rem"
					}
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--copper-dark)",
						"text": "var(--wp--preset--color--white)"
					}
				}
			}
		},
		"blocks": {
			"core/code": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--mono)",
					"fontSize": "var(--wp--preset--font-size--small)"
				},
				"color": {
					"background": "var(--wp--preset--color--gray-900)",
					"text": "var(--wp--preset--color--gray-100)"
				},
				"border": { "radius": "8px" },
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--40)",
						"right": "var(--wp--preset--spacing--40)",
						"bottom": "var(--wp--preset--spacing--40)",
						"left": "var(--wp--preset--spacing--40)"
					}
				}
			},
			"core/quote": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontStyle": "italic",
					"fontSize": "var(--wp--preset--font-size--large)"
				},
				"border": {
					"left": {
						"color": "var(--wp--preset--color--copper)",
						"width": "4px",
						"style": "solid"
					}
				},
				"spacing": {
					"padding": {
						"left": "var(--wp--preset--spacing--40)"
					}
				}
			},
			"core/separator": {
				"color": { "background": "var(--wp--preset--color--gray-200)" }
			},
			"core/navigation": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "500",
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/post-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontWeight": "800"
				}
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontWeight": "700",
					"fontSize": "var(--wp--preset--font-size--x-large)"
				},
				"color": { "text": "var(--wp--preset--color--charcoal)" }
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" },
		{ "name": "sidebar", "title": "Sidebar", "area": "uncategorized" },
		{ "name": "post-meta", "title": "Post Meta", "area": "uncategorized" }
	],
	"customTemplates": [
		{ "name": "page-services", "title": "Services", "postTypes": ["page"] },
		{ "name": "page-portfolio", "title": "Portfolio", "postTypes": ["page"] },
		{ "name": "page-about", "title": "About", "postTypes": ["page"] },
		{ "name": "page-contact", "title": "Contact", "postTypes": ["page"] }
	]
}
